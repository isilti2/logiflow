generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String   @default("")
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  areas               DepotArea[]
  cargo               CargoItem[]
  optimizations       OptimizationRun[]
  teamMembers         TeamMember[]
  apiKeys             ApiKey[]
  notifications       AppNotification[]
  templates           OptTemplate[]
  passwordResetTokens PasswordResetToken[]
  musteriler          Musteri[]
  seferler            Sefer[]
  maliIslemler        MaliIslem[]
  personeller         Personel[]
  puantajlar          Puantaj[]
}

model DepotArea {
  id       String @id @default(cuid())
  userId   String
  name     String
  location String @default("")
  capacity Int    @default(50)

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cargo CargoItem[]

  @@index([userId])
}

model CargoItem {
  id         String   @id @default(cuid())
  userId     String
  areaId     String
  name       String
  type       String
  weight     Float
  dimensions String
  date       String
  status     String   @default("depolarda")
  shelf      String?
  row        Int?
  col        Int?
  createdAt  DateTime @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  area DepotArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([areaId])
}

model OptimizationRun {
  id             String   @id @default(cuid())
  userId         String
  date           String
  containerLabel String
  fillPct        Int
  itemCount      Int
  placedCount    Int
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TeamMember {
  id        String @id @default(cuid())
  userId    String
  email     String
  name      String @default("")
  role      String @default("viewer")
  status    String @default("pending")
  invitedAt String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  prefix    String
  keyHash   String
  scopes    String    @default("[]")
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  lastUsed  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AppNotification {
  id      String   @id @default(cuid())
  userId  String
  type    String
  title   String
  message String
  read    Boolean  @default(false)
  time    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OptTemplate {
  id      String   @id @default(cuid())
  userId  String
  name    String
  items   String
  savedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String?
  action    String
  module    String
  ip        String?
  type      String   @default("info")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

// ─── Lojistik Muhasebe ───────────────────────────────────────

model Musteri {
  id        String   @id @default(cuid())
  userId    String
  ad        String
  vergiNo   String   @default("")
  telefon   String   @default("")
  email     String   @default("")
  adres     String   @default("")
  createdAt DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  seferler Sefer[]
  islemler MaliIslem[]

  @@index([userId])
}

model Sefer {
  id            String   @id @default(cuid())
  userId        String
  musteriId     String?
  aracPlaka     String
  rotaDan       String
  rotaAya       String
  mesafeKm      Float    @default(0)
  tarih         String
  yukAgirligi   Float    @default(0)
  seferUcreti   Float    @default(0)
  yakitMaliyeti Float    @default(0)
  notlar        String   @default("")
  durum         String   @default("planlandi")
  createdAt     DateTime @default(now())

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  musteri  Musteri?    @relation(fields: [musteriId], references: [id])
  islemler MaliIslem[]

  @@index([userId])
}

model MaliIslem {
  id        String   @id @default(cuid())
  userId    String
  seferId   String?
  musteriId String?
  tur       String
  kategori  String
  tutar     Float
  kdvOrani  Float    @default(0)
  aciklama  String   @default("")
  tarih     String
  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sefer   Sefer?   @relation(fields: [seferId], references: [id])
  musteri Musteri? @relation(fields: [musteriId], references: [id])

  @@index([userId])
  @@index([seferId])
}

model Personel {
  id              String   @id @default(cuid())
  userId          String
  ad              String
  unvan           String   @default("")
  telefon         String   @default("")
  tcNo            String   @default("")
  maas            Float    @default(0)
  baslangicTarihi String
  aktif           Boolean  @default(true)
  createdAt       DateTime @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  puantajlar Puantaj[]

  @@index([userId])
}

model Puantaj {
  id         String   @id @default(cuid())
  personelId String
  userId     String
  tarih      String
  girisSaati String?
  cikisSaati String?
  fazlaMesai Float    @default(0)
  izinTuru   String?
  notlar     String   @default("")
  createdAt  DateTime @default(now())

  personel Personel @relation(fields: [personelId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([personelId, tarih])
  @@index([personelId])
  @@index([userId])
}
